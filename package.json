{
  "name": "playbooks-mcp",
  "version": "1.0.0",
  "publisher": "davidrsch",
  "description": "MCP server that exposes OpenMono Playbooks — typed, multi-step AI workflows with human-in-the-loop gates, checkpointing, and composability — to any MCP-compatible agent.",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "node": ">=18.0.0",
    "vscode": "^1.60.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidrsch/playbooks-mcp"
  },
  "bugs": {
    "url": "https://github.com/davidrsch/playbooks-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "check": "npm run lint && npm run format && npm run test && npm run build",
    "package": "vsce package --no-dependencies",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "playbooks",
    "openmono",
    "ai-workflows",
    "model-context-protocol",
    "workflow-orchestration"
  ],
  "homepage": "https://github.com/davidrsch/playbooks-mcp",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "ovsx": "^0.10.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.0"
  }
}
